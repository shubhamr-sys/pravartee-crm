# =============================================================================
# Pravartee CRM — environment variables (python-decouple)
# Copy to .env and never commit .env to version control.
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Add your LAN IP for network access, e.g. 192.168.1.100 (ipconfig getifaddr en0)
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL 16+ — database: pravartee_crm, user: crm_user
# -----------------------------------------------------------------------------
DB_NAME=pravartee_crm
DB_USER=crm_user
DB_PASSWORD=change_me_strong_password
DB_HOST=localhost
DB_PORT=5432

# Connection pooling (Gunicorn/uWSGI — reuse connections across requests)
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

# Timeouts and session options (passed to libpq / psycopg)
DB_CONNECT_TIMEOUT=10
DB_OPTIONS=-c search_path=public

# SSL: leave empty for local dev; use 'require' or 'verify-full' in production
DB_SSLMODE=

# Optional
DB_ATOMIC_REQUESTS=False
DB_TEST_NAME=test_pravartee_crm

# CORS (development)
CORS_ALLOWED_ORIGINS=http://localhost:3034,http://127.0.0.1:3034
CORS_ALLOW_ALL_ORIGINS=True

# Django admin / forms over LAN IP (set by ./start.sh)
CSRF_TRUSTED_ORIGINS=

# Logging
DJANGO_LOG_LEVEL=INFO

# JWT (djangorestframework-simplejwt)
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Pricing request notifications
PRICING_COMMERCIAL_EMAILS=commercial@pravarteesales.com
PRICING_PURCHASE_EMAILS=purchase@pravarteesales.com
# Public URL for pricing-request emails (use LAN IP or domain, not localhost)
# With ./start-https.sh this is set automatically from detect_app_host.
FRONTEND_PUBLIC_URL=http://localhost:3034
DEFAULT_FROM_EMAIL=crm@pravarteesales.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# -----------------------------------------------------------------------------
# Production only (DJANGO_SETTINGS_MODULE=config.settings.production)
# -----------------------------------------------------------------------------
# DEBUG=False
# DB_SSLMODE=require
# SECURE_SSL_REDIRECT=True
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
