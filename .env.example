# =============================================================================
# Pravartee CRM — root plug-and-play configuration
# Copy to .env and run: ./start.sh
# =============================================================================

# Application host (LAN IP or domain). Auto-detected on Ubuntu if left empty.
APP_HOST=

# Service ports — change freely
BACKEND_PORT=8084
FRONTEND_PORT=3034
POSTGRES_PORT=5432

# Bind addresses (0.0.0.0 = accessible on network)
BACKEND_HOST=0.0.0.0
FRONTEND_HOST=0.0.0.0

# With HTTPS, set true to keep Django on 127.0.0.1 only (API via Next.js proxy).
BACKEND_LOCALHOST_ONLY=false

# PostgreSQL (Docker)
POSTGRES_PASSWORD=change_me_strong_password

# Django
SECRET_KEY=change-me-generate-a-random-secret-key
DEBUG=True

# Set false to skip Docker PostgreSQL (if you run Postgres natively)
START_POSTGRES=true

# Set true to run migrations + seed on every start
RUN_SETUP=true

# Set true (or run ./start-https.sh) for HTTPS on the frontend — required for GPS
# on phones/tablets accessing the app via LAN IP (http://IP is blocked by browsers).
ENABLE_HTTPS=false

# Public CRM hostname (Cloudflare Tunnel). When set, overrides FRONTEND_PUBLIC_URL in backend/.env.
# Example: crm.pravarteesales.com
PUBLIC_CRM_HOST=
